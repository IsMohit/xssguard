# ─────────────────────────────────────────────────────────────
# XSSGuard — Environment Variables
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── Flask ──────────────────────────────────────────────────
FLASK_ENV=development
FLASK_SECRET_KEY=replace-this-with-a-long-random-string-at-least-32-chars
FLASK_DEBUG=True

# ── Firebase (Server-Side Admin SDK) ───────────────────────
# Download from Firebase Console → Project Settings → Service Accounts
# → Generate New Private Key → save as firebase_service_account.json
FIREBASE_SERVICE_ACCOUNT_PATH=config/firebase_service_account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Firebase (Client-Side — used by frontend JS) ───────────
# Copy from Firebase Console → Project Settings → Your Apps → SDK setup
FIREBASE_API_KEY=AIzaSy-your-api-key-here
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ── ML Model ────────────────────────────────────────────────
MODEL_PATH=ml_model/xss_cnn_lstm_model.h5
TOKENIZER_PATH=ml_model/tokenizer.pkl

# ── API Settings ────────────────────────────────────────────
MAX_INPUT_LENGTH=10000
RATE_LIMIT_PER_HOUR=1000
